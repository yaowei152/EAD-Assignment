@*
    Name: <YOUR NAME>
    Admin No: 241036U
    Tutorial Group: <TUTORIAL GROUP>
*@
@page
@model ArcaneVault.Web.Pages.CollectionItems.IndexModel
@{
    ViewData["Title"] = "My Collection";
}

<div class="page-header">
    <span class="eyebrow">Signed in as @User.Identity!.Name</span>
    <h1 class="mt-2">My Collection</h1>
    <p class="text-muted">Items you own, organised by category.</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success" data-toast role="status">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" data-toast role="alert">@Model.ErrorMessage</div>
}

<div class="toolbar">
    <form method="get" role="search">
        <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <input type="text" name="Search" value="@Model.Search" class="form-control" placeholder="Search by name, category, or quantity..." aria-label="Search collection" />
        </div>
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrEmpty(Model.Search))
        {
            <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
        }
    </form>
    <a asp-page="Create" class="btn btn-primary">+ Add Item</a>
</div>

@if (Model.Items.Count == 0)
{
    <div class="empty-state" data-reveal>
        <div class="empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8V21H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
        </div>
        @if (!string.IsNullOrEmpty(Model.Search))
        {
            <h2>No items match "@Model.Search"</h2>
            <p>Try a different name, category, or quantity — or clear the search to see everything in your vault.</p>
            <a asp-page="Index" class="btn btn-outline-primary">Clear Search</a>
        }
        else
        {
            <h2>Your vault is empty</h2>
            <p>Every collection starts with a single treasure. Add your first item and watch your vault come to life.</p>
            <a asp-page="Create" class="btn btn-primary">Add Your First Item</a>
        }
    </div>
}
else
{
    <div class="item-grid" data-reveal-group>
        @foreach (var item in Model.Items)
        {
            <article class="item-card">
                <h2 class="item-name">@item.ItemName</h2>
                <div class="item-cats">
                    @if (item.Categories.Count == 0)
                    {
                        <span class="text-muted small">Uncategorised</span>
                    }
                    else
                    {
                        foreach (var category in item.Categories)
                        {
                            <span class="badge bg-secondary">@category.CategoryName</span>
                        }
                    }
                </div>
                <div class="item-stats">
                    <div class="item-stat">
                        <div class="num">@item.StartingQuantity</div>
                        <div class="lbl">Starting</div>
                    </div>
                    <div class="item-stat">
                        <div class="num">@item.CurrentQuantity</div>
                        <div class="lbl">Current</div>
                    </div>
                </div>
                <div class="item-actions">
                    <a asp-page="Details" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-secondary">Details</a>
                    <a asp-page="Edit" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-primary">Edit</a>
                    <a asp-page="Delete" asp-route-id="@item.ItemId" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </article>
        }
    </div>
}
