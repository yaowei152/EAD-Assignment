*@
@page
@model ArcaneVault.Web.Pages.CollectionItems.CreateModel
@{
    ViewData["Title"] = "Add Collection Item";
}

<nav class="crumbs" aria-label="Breadcrumb">
    <a asp-page="Index">My Collection</a>
    <span class="sep" aria-hidden="true">/</span>
    <span aria-current="page">Add Item</span>
</nav>

<div class="page-header">
    <h1>Add Collection Item</h1>
    <p class="text-muted">A new treasure enters the vault.</p>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="vault-panel">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Input.ItemName" class="form-label"></label>
                    <input asp-for="Input.ItemName" class="form-control" placeholder="e.g. Charizard Holo 1st Edition" />
                    <span asp-validation-for="Input.ItemName" class="text-danger"></span>
                </div>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label asp-for="Input.StartingQuantity" class="form-label"></label>
                        <input asp-for="Input.StartingQuantity" type="number" min="0" class="form-control" />
                        <div class="form-text">How many you own right now. Fixed after creation.</div>
                        <span asp-validation-for="Input.StartingQuantity" class="text-danger"></span>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label asp-for="Input.CurrentQuantity" class="form-label"></label>
                        <input asp-for="Input.CurrentQuantity" type="number" min="0" class="form-control" />
                        <span asp-validation-for="Input.CurrentQuantity" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-4">
                    <label asp-for="Input.CategoryCodes" class="form-label"></label>
                    <div class="pill-checks">
                        @foreach (var category in Model.AvailableCategories)
                        {
                            <label class="pill-check">
                                <input type="checkbox" name="Input.CategoryCodes" value="@category.CategoryCode"
                                       checked="@(Model.Input.CategoryCodes.Contains(category.CategoryCode))" />
                                <span>@category.CategoryName</span>
                            </label>
                        }
                    </div>
                    <div class="form-text">Tap to toggle — an item can belong to several categories.</div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Add Item</button>
                    <a asp-page="Index" class="btn btn-link">Cancel</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-5">
        <aside class="form-aside">
            <h3>Good to know</h3>
            <ul>
                <li><strong>Starting quantity</strong> is a permanent record of how many you had when the item first entered your vault — it can never be edited later.</li>
                <li><strong>Current quantity</strong> is the live count, and the only quantity you can update as you buy, sell, or trade.</li>
                <li>Items without a category still appear in your collection — you can tag them any time.</li>
            </ul>
        </aside>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
