@page "{id:int}"
@model ArcaneVault.Web.Pages.CollectionItems.EditModel
@{
    ViewData["Title"] = "Edit Collection Item";
}

<nav class="crumbs" aria-label="Breadcrumb">
    <a asp-page="Index">My Collection</a>
    <span class="sep" aria-hidden="true">/</span>
    <span aria-current="page">Edit Item</span>
</nav>

<div class="page-header">
    <h1>Edit Collection Item</h1>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="vault-panel">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Input.ItemName" class="form-label"></label>
                    <input asp-for="Input.ItemName" class="form-control" />
                    <span asp-validation-for="Input.ItemName" class="text-danger"></span>
                </div>
                <div class="row">
                    <div class="col-sm-6 mb-3">
                        <label asp-for="Input.StartingQuantity" class="form-label"></label>
                        <input asp-for="Input.StartingQuantity" type="number" class="form-control" readonly />
                        <div class="form-text">Fixed at creation and cannot be changed.</div>
                    </div>
                    <div class="col-sm-6 mb-3">
                        <label asp-for="Input.CurrentQuantity" class="form-label"></label>
                        <input asp-for="Input.CurrentQuantity" type="number" min="0" class="form-control" />
                        <span asp-validation-for="Input.CurrentQuantity" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-4">
                    <label asp-for="Input.CategoryCodes" class="form-label"></label>
                    <div class="pill-checks">
                        @foreach (var category in Model.AvailableCategories)
                        {
                            <label class="pill-check">
                                <input type="checkbox" name="Input.CategoryCodes" value="@category.CategoryCode"
                                       checked="@(Model.Input.CategoryCodes.Contains(category.CategoryCode))" />
                                <span>@category.CategoryName</span>
                            </label>
                        }
                    </div>
                    <div class="form-text">Tap to toggle — an item can belong to several categories.</div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-page="Index" class="btn btn-link">Cancel</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-5">
        <aside class="form-aside">
            <h3>Good to know</h3>
            <ul>
                <li><strong>Starting quantity</strong> is locked — it records the size of your holding when the item first entered the vault.</li>
                <li>Update <strong>current quantity</strong> whenever you buy, sell, or trade.</li>
                <li>Category changes take effect immediately across search and analytics.</li>
            </ul>
        </aside>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
