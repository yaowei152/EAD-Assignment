@*
    Name: <YOUR NAME>
    Admin No: 241036U
    Tutorial Group: <TUTORIAL GROUP>
*@
@page
@model ArcaneVault.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log In";
}

<div class="auth-shell">
    <div class="auth-card">
        <h1>Log In</h1>
        <p class="text-muted mb-4">Welcome back to your vault.</p>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success" data-toast role="status">@Model.SuccessMessage</div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label asp-for="Input.UserName" class="form-label"></label>
                <input asp-for="Input.UserName" class="form-control" autocomplete="username" autofocus />
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <div class="password-wrap">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                    <button type="button" class="password-toggle" aria-label="Show password" aria-pressed="false">
                        <svg class="eye-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                        <svg class="eye-closed" style="display:none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 3 18 18"/><path d="M10.6 5.1A9.8 9.8 0 0 1 12 5c6.5 0 10 7 10 7a17.6 17.6 0 0 1-3 3.9M6.6 6.6C4 8.3 2 12 2 12s3.5 7 10 7c1.9 0 3.6-.6 5-1.4"/><path d="M9.9 9.9a3 3 0 0 0 4.2 4.2"/></svg>
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-2">Log In</button>
            <a asp-page="/Account/Register" class="btn btn-link w-100">Need an account? Register</a>
        </form>

        <hr />
        <p class="text-muted small mb-0">Seeded Staff account for testing: username <code>admin</code>, password <code>Admin@123</code></p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
