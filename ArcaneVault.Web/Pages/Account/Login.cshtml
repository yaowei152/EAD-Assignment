@*
    Name: <YOUR NAME>
    Admin No: 241036U
    Tutorial Group: <TUTORIAL GROUP>
*@
@page
@model ArcaneVault.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log In";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h1>Log In</h1>

        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label asp-for="Input.UserName" class="form-label"></label>
                <input asp-for="Input.UserName" class="form-control" autocomplete="username" autofocus />
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Log In</button>
            <a asp-page="/Account/Register" class="btn btn-link">Need an account? Register</a>
        </form>

        <hr />
        <p class="text-muted small">Seeded Staff account for testing: username <code>admin</code>, password <code>Admin@123</code></p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
