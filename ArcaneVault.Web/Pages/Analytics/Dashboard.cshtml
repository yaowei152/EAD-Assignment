@page
@using System.Text.Json
@model ArcaneVault.Web.Pages.Analytics.DashboardModel
@{
    ViewData["Title"] = "Analytics Dashboard";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
}

<h1>Analytics Dashboard</h1>
<p class="text-muted">Platform-wide insight into popular items, category demand, and collector activity across all users.</p>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="display-6">@Model.Summary.TotalUsers</div>
                <div class="text-muted">Registered Users</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="display-6">@Model.Summary.TotalCategories</div>
                <div class="text-muted">Categories</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="display-6">@Model.Summary.TotalItems</div>
                <div class="text-muted">Collection Items</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="display-6">@Model.Summary.TotalQuantityAcrossAllItems</div>
                <div class="text-muted">Total Quantity Held</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Most Popular Items</h2>
                <p class="text-muted small">Ranked by total quantity currently held across all collectors. Click a bar to search for that item in your own collection.</p>
                @if (Model.PopularItems.Count == 0)
                {
                    <p class="text-muted">No data yet.</p>
                }
                else
                {
                    <canvas id="popularItemsChart" height="220"></canvas>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Category Demand</h2>
                <p class="text-muted small">Share of total held quantity by category.</p>
                @if (Model.CategoryDemand.Count == 0 || Model.CategoryDemand.All(c => c.TotalQuantity == 0))
                {
                    <p class="text-muted">No data yet.</p>
                }
                else
                {
                    <canvas id="categoryDemandChart" height="220"></canvas>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Most Active Collectors</h2>
                <p class="text-muted small">Ranked by total quantity held across their collection.</p>
                @if (Model.UserActivity.Count == 0)
                {
                    <p class="text-muted">No data yet.</p>
                }
                else
                {
                    <canvas id="userActivityChart" height="220"></canvas>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script>
        const popularItems = @Html.Raw(JsonSerializer.Serialize(Model.PopularItems, jsonOptions));
        const categoryDemand = @Html.Raw(JsonSerializer.Serialize(Model.CategoryDemand.Where(c => c.TotalQuantity > 0), jsonOptions));
        const userActivity = @Html.Raw(JsonSerializer.Serialize(Model.UserActivity, jsonOptions));

        const palette = ['#6f42c1', '#0d6efd', '#20c997', '#fd7e14', '#d63384', '#198754', '#0dcaf0', '#ffc107', '#6610f2', '#dc3545'];

        if (popularItems.length > 0) {
            new Chart(document.getElementById('popularItemsChart'), {
                type: 'bar',
                data: {
                    labels: popularItems.map(i => i.itemName),
                    datasets: [{
                        label: 'Total quantity held',
                        data: popularItems.map(i => i.totalCurrentQuantity),
                        backgroundColor: '#0d6efd'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
                    onClick: (evt, elements) => {
                        if (elements.length === 0) return;
                        const label = popularItems[elements[0].index].itemName;
                        window.location.href = '/CollectionItems?Search=' + encodeURIComponent(label);
                    }
                }
            });
        }

        if (categoryDemand.length > 0) {
            new Chart(document.getElementById('categoryDemandChart'), {
                type: 'doughnut',
                data: {
                    labels: categoryDemand.map(c => c.categoryName),
                    datasets: [{
                        data: categoryDemand.map(c => c.totalQuantity),
                        backgroundColor: palette
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'right' } }
                }
            });
        }

        if (userActivity.length > 0) {
            new Chart(document.getElementById('userActivityChart'), {
                type: 'bar',
                data: {
                    labels: userActivity.map(u => u.userName),
                    datasets: [{
                        label: 'Total quantity held',
                        data: userActivity.map(u => u.totalQuantityHeld),
                        backgroundColor: '#20c997'
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: { x: { beginAtZero: true, ticks: { precision: 0 } } }
                }
            });
        }
    </script>
}
