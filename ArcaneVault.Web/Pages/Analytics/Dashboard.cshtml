    Name: <YOUR NAME>
    Admin No: 241036U
    Tutorial Group: <TUTORIAL GROUP>
*@
@page
@using System.Text.Json
@model ArcaneVault.Web.Pages.Analytics.DashboardModel
@{
    ViewData["Title"] = "Analytics Dashboard";
    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
}

<div class="page-header">
    <h1>Analytics Dashboard</h1>
    <p class="text-muted">Platform-wide insight into popular items, category demand, and collector activity across all users.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-3 mb-4" data-reveal-group>
    <div class="col-6 col-xl-3">
        <div class="stat-card h-100">
            <div>
                <div class="stat-label">Registered Users</div>
                <div class="stat-value" data-counter="@Model.Summary.TotalUsers">@Model.Summary.TotalUsers</div>
            </div>
            <div class="icon-tile icon-tile--indigo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card h-100">
            <div>
                <div class="stat-label">Categories</div>
                <div class="stat-value" data-counter="@Model.Summary.TotalCategories">@Model.Summary.TotalCategories</div>
            </div>
            <div class="icon-tile icon-tile--purple">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 8-9-6-9 6 9 6 9-6Z"/><path d="m3 8 9 6 9-6"/><path d="M3 16l9 6 9-6"/></svg>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card h-100">
            <div>
                <div class="stat-label">Collection Items</div>
                <div class="stat-value" data-counter="@Model.Summary.TotalItems">@Model.Summary.TotalItems</div>
            </div>
            <div class="icon-tile icon-tile--gold">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8V21H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
            </div>
        </div>
    </div>
    <div class="col-6 col-xl-3">
        <div class="stat-card h-100">
            <div>
                <div class="stat-label">Total Quantity Held</div>
                <div class="stat-value" data-counter="@Model.Summary.TotalQuantityAcrossAllItems">@Model.Summary.TotalQuantityAcrossAllItems</div>
            </div>
            <div class="icon-tile icon-tile--green">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18.7 8 13 13.7l-3-3L4 16.6"/></svg>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="chart-card chart-card--gradient h-100">
            <h2>Most Popular Items</h2>
            <p class="chart-subtitle">Ranked by total quantity currently held across all collectors. Click a bar to search for that item in your own collection.</p>
            @if (Model.PopularItems.Count == 0)
            {
                <p class="chart-subtitle">No data yet.</p>
            }
            else
            {
                <canvas id="popularItemsChart" height="220"></canvas>
            }
        </div>
    </div>
    <div class="col-lg-5">
        <div class="chart-card h-100">
            <h2>Category Demand</h2>
            <p class="chart-subtitle">Share of total held quantity by category.</p>
            @if (Model.CategoryDemand.Count == 0 || Model.CategoryDemand.All(c => c.TotalQuantity == 0))
            {
                <p class="text-muted">No data yet.</p>
            }
            else
            {
                <canvas id="categoryDemandChart" height="220"></canvas>
            }
        </div>
    </div>
    <div class="col-12">
        <div class="chart-card">
            <h2>Most Active Collectors</h2>
            <p class="chart-subtitle">Ranked by total quantity held across their collection.</p>
            @if (Model.UserActivity.Count == 0)
            {
                <p class="text-muted">No data yet.</p>
            }
            else
            {
                <canvas id="userActivityChart" height="120"></canvas>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
    <script>
        const popularItems = @Html.Raw(JsonSerializer.Serialize(Model.PopularItems, jsonOptions));
        const categoryDemand = @Html.Raw(JsonSerializer.Serialize(Model.CategoryDemand.Where(c => c.TotalQuantity > 0), jsonOptions));
        const userActivity = @Html.Raw(JsonSerializer.Serialize(Model.UserActivity, jsonOptions));

        const palette = ['#6366f1', '#f2c94c', '#10b981', '#38bdf8', '#f472b6', '#a78bfa', '#fb923c', '#34d399', '#818cf8', '#facc15'];
        const gridColor = 'rgba(255, 255, 255, 0.08)';
        const textColor = '#94a3b8';

        Chart.defaults.color = textColor;
        Chart.defaults.font.family = "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif";
        Chart.defaults.borderColor = gridColor;

        if (popularItems.length > 0) {
            // White bars on the gradient card, Soft UI style
            new Chart(document.getElementById('popularItemsChart'), {
                type: 'bar',
                data: {
                    labels: popularItems.map(i => i.itemName),
                    datasets: [{
                        label: 'Total quantity held',
                        data: popularItems.map(i => i.totalCurrentQuantity),
                        backgroundColor: 'rgba(255, 255, 255, 0.9)',
                        hoverBackgroundColor: '#ffffff',
                        borderRadius: 8,
                        maxBarThickness: 36
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0, color: 'rgba(255, 255, 255, 0.75)' },
                            grid: { color: 'rgba(255, 255, 255, 0.12)' }
                        },
                        x: {
                            ticks: { color: 'rgba(255, 255, 255, 0.75)' },
                            grid: { display: false }
                        }
                    },
                    onClick: (evt, elements) => {
                        if (elements.length === 0) return;
                        const label = popularItems[elements[0].index].itemName;
                        window.location.href = '/CollectionItems?Search=' + encodeURIComponent(label);
                    }
                }
            });
        }

        if (categoryDemand.length > 0) {
            new Chart(document.getElementById('categoryDemandChart'), {
                type: 'doughnut',
                data: {
                    labels: categoryDemand.map(c => c.categoryName),
                    datasets: [{
                        data: categoryDemand.map(c => c.totalQuantity),
                        backgroundColor: palette,
                        borderColor: '#0f1526',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: { legend: { position: 'right', labels: { color: textColor } } }
                }
            });
        }

        if (userActivity.length > 0) {
            new Chart(document.getElementById('userActivityChart'), {
                type: 'bar',
                data: {
                    labels: userActivity.map(u => u.userName),
                    datasets: [{
                        label: 'Total quantity held',
                        data: userActivity.map(u => u.totalQuantityHeld),
                        backgroundColor: '#f2c94c',
                        borderRadius: 6,
                        maxBarThickness: 28
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    plugins: { legend: { display: false } },
                    scales: {
                        x: { beginAtZero: true, ticks: { precision: 0, color: textColor }, grid: { color: gridColor } },
                        y: { ticks: { color: textColor }, grid: { display: false } }
                    }
                }
            });
        }
    </script>
}
