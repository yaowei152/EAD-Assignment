*@
@page "{code}"
@model ArcaneVault.Web.Pages.Categories.EditModel
@{
    ViewData["Title"] = "Edit Category";
}

<nav class="crumbs" aria-label="Breadcrumb">
    <a asp-page="Index">Categories</a>
    <span class="sep" aria-hidden="true">/</span>
    <span aria-current="page">Edit Category</span>
</nav>

<div class="page-header">
    <h1>Edit Category</h1>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="vault-panel">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.CategoryCode" class="form-label"></label>
                <input asp-for="Input.CategoryCode" class="form-control" readonly />
                <div class="form-text">Category code cannot be changed after creation.</div>
            </div>
            <div class="mb-3">
                <label asp-for="Input.CategoryName" class="form-label"></label>
                <input asp-for="Input.CategoryName" class="form-control" />
                <span asp-validation-for="Input.CategoryName" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="Index" class="btn btn-link">Cancel</a>
        </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
