@page "{code}"
@model ArcaneVault.Web.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Delete Category";
}

<h1>Delete Category</h1>

<div class="alert alert-warning">Are you sure you want to delete this category? This cannot be undone.</div>

@if (Model.Category is not null)
{
    <dl class="row">
        <dt class="col-sm-3">Category Code</dt>
        <dd class="col-sm-9">@Model.Category.CategoryCode</dd>

        <dt class="col-sm-3">Category Name</dt>
        <dd class="col-sm-9">@Model.Category.CategoryName</dd>

        <dt class="col-sm-3">Items Using This Category</dt>
        <dd class="col-sm-9">@Model.Category.ItemCount</dd>
    </dl>

    @if (Model.Category.ItemCount > 0)
    {
        <div class="alert alert-danger">
            This category is currently assigned to @Model.Category.ItemCount item(s) and cannot be deleted until it is removed from them.
        </div>
    }

    <form method="post">
        <button type="submit" class="btn btn-danger" @(Model.Category.ItemCount > 0 ? "disabled" : "")>Delete</button>
        <a asp-page="Index" class="btn btn-link">Cancel</a>
    </form>
}
